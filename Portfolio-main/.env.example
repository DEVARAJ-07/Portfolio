# Copy this file to `.env` and fill the values with your EmailJS credentials or serverless backend settings.
# Then restart the dev server.

# EmailJS configuration for direct client-side form sending.
# Create an EmailJS service and template at https://www.emailjs.com/.
# Template variables should include: from_name, from_email, message.
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Netlify function endpoint used as a fallback or deployed backend.
VITE_SERVERLESS_ENDPOINT=/.netlify/functions/send-email
VITE_CONTACT_EMAIL=devarajsubramani20@gmail.com

# SMTP settings are used by the Netlify function.
# Configure these in Netlify site settings or local Netlify CLI, not in source control.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
EMAIL_FROM=portfolio@yourdomain.com
EMAIL_TO=devarajsubramani20@gmail.com
